# Copy this file to `config/site.env.local` or generate it with
# `bash scripts/restore_local_site_env.sh ...`.

WAFERDB_SCHEME=http
WAFERDB_HOST=127.0.0.1
WAFERDB_PORT=8081
WAFERDB_CONTEXT_PATH=/WaferDb

# Local defaults keep data under the repo. Replace these for a real server.
WAFERDB_DB_PATH=/path/to/WaferDb/data/waferdb.sqlite
WAFERDB_DARKFIELD_ROOT=/path/to/WaferDb/data/darkfield

WAFERDB_ALLOWED_ORIGIN=*
WAFERDB_DIST_LABEL=local

# Optional explicit override if your API root does not match the fields above.
# WAFERDB_API_BASE=http://127.0.0.1:8081/WaferDb/api
